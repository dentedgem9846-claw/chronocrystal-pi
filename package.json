{
  "name": "chronocrystal-pi",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "start:prod": "bun dist/index.js",
    "build": "bun build src/index.ts --target bun --minify --outfile dist/index.js --packages external",
    "check": "bunx biome check --write --error-on-warnings . && tsc --noEmit",
    "test": "bun test",
    "smoke:prod": "bun run test/smoke/prod.ts",
    "smoke:prod:deploy": "bun run scripts/smoke.ts",
    "deploy": "bun run scripts/deploy.ts",
    "deploy:check": "bun run scripts/deploy.ts --check-only",
    "smoke:pi-subagent": "bun run test/smoke/pi-subagent.ts",
    "pi:agent": "bun run src/pi-agent-cli.ts",
    "prepare": "bun .husky/install.mjs"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-coding-agent": "latest",
    "@mariozechner/pi-agent-core": "latest",
    "@mariozechner/pi-mom": "latest",
    "pino": "latest",
    "simplex-chat": "latest",
    "@simplex-chat/types": "latest",
    "tiddlywiki": "latest",
    "qrcode": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "latest",
    "biome": "latest",
    "husky": "latest"
  }
}
