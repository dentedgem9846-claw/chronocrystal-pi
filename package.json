{
	"name": "chronocrystal-pi",
	"module": "src/index.ts",
	"type": "module",
	"scripts": {
		"start": "bun run src/index.ts",
		"start:prod": "bun run dist/index.js",
		"build": "bun run scripts/build-embed.ts && bun build src/index.ts --compile --outfile dist/chronocrystal --target bun-linux-x64-baseline",
		"build:dev": "bun run scripts/build-embed.ts && bun build src/index.ts --outfile dist/index.js --minify --format esm --packages external",
		"format": "biome format --write .",
		"check": "biome check . && tsc --noEmit",
		"test": "bun test",
		"e2e": "echo 'No e2e tests configured'",
		"prepare": "bun .husky/install.mjs"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "latest",
		"@mariozechner/pi-ai": "latest",
		"@mariozechner/pi-coding-agent": "latest",
		"@mariozechner/pi-mom": "latest",
		"@simplex-chat/types": "latest",
		"pino": "latest",
		"qrcode": "^1.5.4",
		"simplex-chat": "latest",
		"tiddlywiki": "latest"
	},
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@types/bun": "latest",
		"@types/qrcode": "^1.5.6",
		"husky": "latest"
	}
}
